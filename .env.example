# ─────────────────────────────────────────────────────────────────────────────
# OpenPropFirm — Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to the repository.
# ─────────────────────────────────────────────────────────────────────────────

# Public site URL (used for canonical URLs, sitemap, OG tags)
# Update when domain is purchased
NEXT_PUBLIC_SITE_URL=https://openpropfirm.com

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Get both values from: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase service role key — FULL DATABASE WRITE ACCESS
# ⚠️  GITHUB ACTIONS SECRET ONLY. NEVER set this as a Vercel env var or in .env.local.
# Used exclusively by the monitoring bot to write usage logs.
# Get from: Supabase Dashboard → Project Settings → API → service_role key
SUPABASE_SERVICE_KEY=your-service-role-key-here

# ─── Google OAuth (via Supabase) ──────────────────────────────────────────────
# Auth method: Google OAuth only (resolved 2026-03-29)
# Setup:
#   1. Go to Google Cloud Console → APIs & Services → Credentials
#   2. Create OAuth 2.0 Client ID (Web application)
#   3. Add authorized redirect URI:
#      https://[your-supabase-project-id].supabase.co/auth/v1/callback
#   4. Enable Google provider in Supabase Dashboard → Authentication → Providers → Google
GOOGLE_OAUTH_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-google-client-secret

# ─── GitHub Actions Secrets (reference only — do not set in Vercel or .env.local) ─
# Issue number of the bot health check GitHub issue (created manually before Sprint 6)
# HEALTH_CHECK_ISSUE_NUMBER=1

# LLM API key for monitoring bot fallback (Sprint 6)
# ANTHROPIC_API_KEY=your-anthropic-api-key

# ─── Vercel Analytics ────────────────────────────────────────────────────────
# NOTE: NEXT_PUBLIC_VERCEL_ANALYTICS_ID is auto-injected by Vercel.
# Do NOT set it manually — Vercel handles this automatically in production.
